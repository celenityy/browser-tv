# Browser TV - Nightly (ARM) mozconfig

. "${BROWSER_TV_MOZCONFIGS}/core.mozconfig"
. "${BROWSER_TV_MOZCONFIGS}/branding/browser-tv-nightly.mozconfig"
. "${BROWSER_TV_MOZCONFIGS}/targets/arm.mozconfig"

## Set the destination object (output) directory
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj/browser-tv-nightly-arm
mk_add_options OBJDIR=@TOPSRCDIR@/obj/browser-tv-nightly-arm
export MOZ_OBJDIR="${BROWSER_TV_GECKO}/obj/browser-tv-nightly-arm"
