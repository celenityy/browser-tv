
. "${BROWSER_TV_MOZCONFIGS}/branding/common.mozconfig"

ac_add_options --disable-browser-tv-release
ac_add_options --with-app-basename='Browser TV Nightly'
ac_add_options --with-app-name='browser-tv-nightly'
ac_add_options --with-branding='browser-tv/branding/browser-tv-nightly'
export MOZ_APP_BASENAME='Browser TV Nightly'
export MOZ_APP_NAME='browser-tv-nightly'
export MOZ_APP_REMOTINGNAME='browser-tv-nightly'
