
. "$topsrcdir/browser-tv/mozconfigs/core.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/branding/browser-tv.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/targets/arm.mozconfig"

## Set the destination object (output) directory
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj/browser-tv-release-arm
mk_add_options OBJDIR=@TOPSRCDIR@/obj/browser-tv-release-arm
export MOZ_OBJDIR="$topsrcdir/obj/browser-tv-release-arm"
