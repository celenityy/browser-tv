# Browser TV - Nightly (ARM64) mozconfig

. "$topsrcdir/browser-tv/mozconfigs/core.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/branding/browser-tv-nightly.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/targets/arm64.mozconfig"

## Set the destination object (output) directory
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj/browser-tv-nightly-arm64
mk_add_options OBJDIR=@TOPSRCDIR@/obj/browser-tvx-nightly-arm64
export MOZ_OBJDIR="$topsrcdir/obj/browser-tv-nightly-arm64"
