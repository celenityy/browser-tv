# Browser TV - Release (x86_64) mozconfig

. "$topsrcdir/browser-tv/mozconfigs/core.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/branding/browser-tv.mozconfig"
. "$topsrcdir/browser-tv/mozconfigs/targets/x86_64.mozconfig"

## Set the destination object (output) directory
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj/browser-tv-release-x86_64
mk_add_options OBJDIR=@TOPSRCDIR@/obj/browser-tv-release-x86_64
export MOZ_OBJDIR="$topsrcdir/obj/browser-tv-release-x86_64"
